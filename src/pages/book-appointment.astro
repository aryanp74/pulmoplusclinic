---
import BaseLayout from "@layouts/BaseLayout.astro";
import { clinic, actions } from "@data/site";

const appointmentEndpoint = "/api/appointments";

const bookingSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Book an appointment at PulmoPlus",
  description:
    "Request an in-clinic consultation, video consultation, follow-up or report review with PulmoPlus in Noida."
};
---

<BaseLayout
  title="Book Appointment | PulmoPlus Noida"
  description="Request an appointment with PulmoPlus for respiratory, sleep, chest, critical care and general medical concerns in Noida."
  structuredData={bookingSchema}
>
  <section class="booking-hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Book appointment</p>
        <h1>Start with a simple request.</h1>
        <p>
          Share basic details, the earliest date that works for you and the reason
          for your visit. PulmoPlus will review the request and confirm the appointment directly.
        </p>
      </div>

      <aside class="help-panel">
        <h2>Daily consultation format</h2>
        <p>
          Consultations run from <strong>{clinic.dailyConsultationSlot} every day</strong>.
        </p>
        <p>You can request any day. The clinic coordinates appointments manually and confirms the final schedule directly.</p>
        <a class="panel-link focus-ring" href={actions.call}>Call {clinic.phone}</a>
        <a class="panel-link focus-ring" href={actions.whatsapp} target="_blank" rel="noreferrer">
          WhatsApp PulmoPlus
        </a>
      </aside>
    </div>
  </section>

  <section class="section form-section">
    <div class="container form-grid">
      <aside class="privacy-note">
        <p class="eyebrow">Privacy first</p>
        <h2>Your details are used only to contact you about this request.</h2>
        <p>
          Do not use this form for emergencies. If you have severe breathlessness,
          chest pain, bluish lips, confusion or fainting, seek urgent emergency care.
        </p>
      </aside>

      <div class="form-shell">
        <form
          id="appointment-form"
          class="appointment-form"
          action={appointmentEndpoint}
          method="POST"
          novalidate
        >
          <input type="hidden" name="form_name" value="PulmoPlus appointment request" />
          <input type="hidden" name="preferred_time_window" value={clinic.dailyConsultationSlot} />
          <input type="text" name="company" tabindex="-1" autocomplete="off" class="hp-field" aria-hidden="true" />

          <fieldset>
            <legend>1. Type of visit</legend>

            <div class="choice-grid">
              <label>
                <input type="radio" name="visit_type" value="In-clinic consultation" required />
                <span>In-clinic consultation</span>
              </label>

              <label>
                <input type="radio" name="visit_type" value="Video consultation" />
                <span>Video consultation</span>
              </label>

              <label>
                <input type="radio" name="visit_type" value="Follow-up" />
                <span>Follow-up</span>
              </label>

              <label>
                <input type="radio" name="visit_type" value="Report review" />
                <span>Report review</span>
              </label>
            </div>
          </fieldset>

          <fieldset>
            <legend>2. Patient details</legend>

            <div class="field-grid">
              <label>
                <span>Full name</span>
                <input name="patient_name" type="text" autocomplete="name" minlength="2" maxlength="80" required />
              </label>

              <label>
                <span>Age</span>
                <input name="patient_age" type="number" min="0" max="120" inputmode="numeric" required />
              </label>

              <label>
                <span>Phone number</span>
                <input name="phone" type="tel" autocomplete="tel" inputmode="numeric" pattern="[0-9 +()-]{10,20}" minlength="10" maxlength="20" required />
              </label>

              <label>
                <span>WhatsApp number if different</span>
                <input name="whatsapp" type="tel" inputmode="numeric" pattern="[0-9 +()-]{10,20}" minlength="10" maxlength="20" />
              </label>

              <label>
                <span>Email optional</span>
                <input name="email" type="email" autocomplete="email" />
              </label>

              <label>
                <span>Preferred language</span>
                <select name="preferred_language" required>
                  <option value="">Select language</option>
                  <option>English</option>
                  <option>Hindi</option>
                </select>
              </label>
            </div>
          </fieldset>

          <fieldset>
            <legend>3. Reason for visit</legend>

            <label>
              <span>Main concern</span>
              <select name="concern_category" required>
                <option value="">Select concern</option>
                <option>Breathing issue</option>
                <option>Cough</option>
                <option>Sleep or snoring issue</option>
                <option>Asthma or COPD</option>
                <option>Chest infection</option>
                <option>Procedure consultation</option>
                <option>General medical concern</option>
                <option>Other</option>
              </select>
            </label>

            <label>
              <span>Short message optional</span>
              <textarea
                name="message"
                rows="5"
                maxlength="1000"
                placeholder="Briefly describe symptoms, reports, or what you need help with."
              ></textarea>
            </label>
          </fieldset>

          <fieldset>
            <legend>4. Appointment date</legend>

            <div class="field-grid">
              <label>
                <span>Check availability from this date</span>
                <input name="preferred_date" type="date" required />
                <small>
                  Fixed daily consultation slot: {clinic.dailyConsultationSlot}. The clinic confirms the final appointment date directly.
                </small>
              </label>
            </div>
          </fieldset>

          <fieldset>
            <legend>5. Consent</legend>

            <label class="consent">
              <input name="contact_consent" type="checkbox" required />
              <span>
                I consent to PulmoPlus using the information I submit to contact me
                about my appointment or consultation request. I understand this
                website is not for medical emergencies.
              </span>
            </label>
          </fieldset>

          <div class="form-error" data-form-error hidden>
            Please fill the required fields and accept the consent checkbox.
          </div>

          <button class="submit-button focus-ring" type="submit">
            Send appointment request
          </button>

          <p class="form-footnote">
            If a secure form endpoint is configured, this form submits there first and still keeps WhatsApp as fallback.
          </p>

          <p class="form-footnote">
            This request does not auto-block a day. The clinic reviews requests manually and confirms the final appointment directly.
          </p>
        </form>

        <div class="confirmation" data-confirmation hidden>
          <div class="breathing-circle" aria-hidden="true"></div>
          <p class="eyebrow">Request received</p>
          <h2>Your appointment request has been prepared.</h2>
          <p>
            PulmoPlus will confirm your appointment for the daily
            {clinic.dailyConsultationSlot} consultation slot. For faster coordination,
            you can also send the same request on WhatsApp.
          </p>

        <div class="confirmation-actions">
          <a class="primary-action focus-ring" data-whatsapp-confirm data-whatsapp-number={clinic.whatsapp} href={actions.whatsapp} target="_blank" rel="noreferrer">
            Send on WhatsApp
          </a>
          <a class="secondary-action focus-ring" href={`mailto:${clinic.email}`}>Email clinic</a>
        </div>
      </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector("#appointment-form");
  const errorBox = document.querySelector("[data-form-error]");
  const confirmation = document.querySelector("[data-confirmation]");
  const whatsappConfirm = document.querySelector("[data-whatsapp-confirm]");
  const submitButton = form?.querySelector('button[type="submit"]');
  const preferredDateInput = form?.querySelector('input[name="preferred_date"]');
  const confirmationText = confirmation?.querySelector("p:not(.eyebrow)");

  function getValue(formData: FormData, key: string) {
    return String(formData.get(key) || "").trim();
  }

  function getLocalDateString() {
    const now = new Date();
    const offset = now.getTimezoneOffset() * 60000;
    return new Date(now.getTime() - offset).toISOString().split("T")[0];
  }

  function normalizePhone(value: string) {
    return value.replace(/[^\d+]/g, "");
  }

  if (preferredDateInput instanceof HTMLInputElement) {
    preferredDateInput.min = getLocalDateString();
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!(form instanceof HTMLFormElement)) return;
    if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;

    if (!form.checkValidity()) {
      form.reportValidity();
      if (errorBox instanceof HTMLElement) errorBox.hidden = false;
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      return;
    }

    if (errorBox instanceof HTMLElement) errorBox.hidden = true;

    const formData = new FormData(form);
    const honeypot = getValue(formData, "company");

    if (honeypot) {
      form.reset();
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      return;
    }

    const patientName = getValue(formData, "patient_name");
    const phone = normalizePhone(getValue(formData, "phone"));
    const visitType = getValue(formData, "visit_type");
    const patientAge = getValue(formData, "patient_age");
    const whatsapp = normalizePhone(getValue(formData, "whatsapp"));
    const email = getValue(formData, "email");
    const preferredLanguage = getValue(formData, "preferred_language");
    const concern = getValue(formData, "concern_category");
    const date = getValue(formData, "preferred_date");
    const timeWindow = getValue(formData, "preferred_time_window");
    const message = getValue(formData, "message");

    if (date < getLocalDateString()) {
      if (errorBox instanceof HTMLElement) {
        errorBox.textContent = "Please choose today or a future date.";
        errorBox.hidden = false;
      }
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
      return;
    }

    const whatsappMessage = [
      "Hello PulmoPlus, I would like to request the next available appointment with Dr. Priyadarshi J. Kumar.",
      `Name: ${patientName}`,
      `Phone: ${phone}`,
      `Visit type: ${visitType}`,
      `Concern: ${concern}`,
      `Check availability from: ${date}`,
      `Consultation slot: ${timeWindow}`,
      message ? `Message: ${message}` : ""
    ]
      .filter(Boolean)
      .join("\n");

    if (whatsappConfirm instanceof HTMLAnchorElement) {
      const whatsappNumber = whatsappConfirm.dataset.whatsappNumber || "8826300531";
      whatsappConfirm.href = `https://wa.me/91${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
    }

    const action = form.getAttribute("action") || "";

    try {
      const response = await fetch(action, {
        method: "POST",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          form_name: getValue(formData, "form_name"),
          visit_type: visitType,
          patient_name: patientName,
          patient_age: patientAge,
          phone,
          whatsapp,
          email,
          preferred_language: preferredLanguage,
          concern_category: concern,
          message,
          preferred_date: date,
          preferred_time_window: timeWindow,
          contact_consent: formData.get("contact_consent") === "on",
          company: honeypot
        })
      });

      const result = await response.json().catch(() => null);

      if (!response.ok) {
        throw new Error(result?.error || "Request failed");
      }

      if (confirmationText instanceof HTMLElement && result?.message) {
        confirmationText.textContent = result.message;
      }

      form.hidden = true;

      if (confirmation instanceof HTMLElement) {
        confirmation.hidden = false;
        confirmation.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    } catch (error) {
      if (errorBox instanceof HTMLElement) {
        errorBox.textContent =
          error instanceof Error
            ? error.message
            : "Appointment request failed. Please use WhatsApp or call the clinic.";
        errorBox.hidden = false;
      }
    } finally {
      if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
    }
  });
</script>

<style>
  .booking-hero {
    padding: 84px 0;
    background:
      radial-gradient(circle at 82% 28%, rgba(158, 223, 227, 0.56), transparent 32%),
      linear-gradient(180deg, #f7f4ef 0%, #eef7f7 100%);
  }

  .hero-grid,
  .form-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 390px;
    gap: clamp(34px, 6vw, 84px);
    align-items: start;
  }

  .form-grid {
    grid-template-columns: 320px minmax(0, 1fr);
  }

  h1,
  h2 {
    margin: 12px 0 0;
    color: #1d2b2e;
    line-height: 0.98;
    letter-spacing: 0;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(2.5rem, 5.8vw, 5.4rem);
  }

  h2 {
    font-size: clamp(1.8rem, 3.6vw, 3.2rem);
  }

  .booking-hero p,
  .privacy-note p {
    max-width: 660px;
    margin: 24px 0 0;
    color: #536b70;
    font-size: 1.08rem;
  }

  .help-panel {
    border: 1px solid rgba(217, 231, 233, 0.96);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.86);
    padding: 26px;
    box-shadow: 0 24px 80px rgba(15, 111, 120, 0.12);
  }

  .help-panel h2 {
    margin: 0;
    font-size: 1.45rem;
    line-height: 1.1;
  }

  .help-panel p {
    margin: 14px 0 20px;
    font-size: 0.98rem;
  }

  .panel-link {
    display: flex;
    min-height: 46px;
    align-items: center;
    border-top: 1px solid rgba(15, 111, 120, 0.14);
    color: #0f6f78;
    font-weight: 850;
  }

  .form-section {
    background: #ffffff;
  }

  .privacy-note {
    position: sticky;
    top: 104px;
    border-top: 1px solid rgba(15, 111, 120, 0.2);
    padding-top: 18px;
  }

  .privacy-note h2 {
    font-size: clamp(1.7rem, 3vw, 2.45rem);
  }

  .form-shell {
    border-radius: 8px;
    background: #f7f4ef;
    padding: clamp(18px, 3vw, 34px);
    box-shadow: 0 24px 80px rgba(15, 111, 120, 0.1);
  }

  .appointment-form {
    display: grid;
    gap: 28px;
  }

  fieldset {
    display: grid;
    gap: 16px;
    margin: 0;
    border: 0;
    border-top: 1px solid rgba(15, 111, 120, 0.16);
    padding: 24px 0 0;
  }

  fieldset:first-of-type {
    border-top: 0;
    padding-top: 0;
  }

  legend {
    margin-bottom: 2px;
    color: #1d2b2e;
    font-size: 1.2rem;
    font-weight: 900;
  }

  .field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  label {
    display: grid;
    gap: 8px;
    color: #1d2b2e;
    font-weight: 800;
  }

  label span {
    font-size: 0.92rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid rgba(15, 111, 120, 0.2);
    border-radius: 8px;
    background: white;
    color: #1d2b2e;
    padding: 13px 14px;
    outline: 2px solid transparent;
    outline-offset: 3px;
  }

  textarea {
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: #0f6f78;
    outline-color: rgba(15, 111, 120, 0.24);
  }

  .choice-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .choice-grid label {
    position: relative;
    display: block;
  }

  .choice-grid input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .choice-grid span {
    display: flex;
    min-height: 58px;
    align-items: center;
    border: 1px solid rgba(15, 111, 120, 0.18);
    border-radius: 8px;
    background: white;
    padding: 12px 14px;
    color: #536b70;
    font-weight: 850;
    transition:
      background 180ms ease,
      color 180ms ease,
      border-color 180ms ease;
  }

  .choice-grid input:checked + span {
    border-color: #0f6f78;
    background: #eef7f7;
    color: #0f6f78;
  }

  .choice-grid input:focus-visible + span {
    outline: 2px solid #0f6f78;
    outline-offset: 4px;
  }

  .consent {
    grid-template-columns: 22px 1fr;
    gap: 12px;
    align-items: start;
    color: #536b70;
    font-weight: 650;
  }

  .consent input {
    width: 18px;
    height: 18px;
    margin-top: 3px;
  }

  .form-error {
    border-radius: 8px;
    background: rgba(231, 154, 139, 0.16);
    color: #7a3028;
    padding: 12px 14px;
    font-weight: 800;
  }

  .submit-button,
  .primary-action,
  .secondary-action {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0 22px;
    font-weight: 900;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .submit-button,
  .primary-action {
    border: 0;
    background: #0f6f78;
    color: white;
    box-shadow: 0 18px 40px rgba(15, 111, 120, 0.2);
    cursor: pointer;
  }

  .secondary-action {
    border: 1px solid rgba(15, 111, 120, 0.2);
    background: rgba(255, 255, 255, 0.76);
    color: #0f6f78;
  }

  .submit-button:hover,
  .primary-action:hover,
  .secondary-action:hover {
    transform: translateY(-1px);
  }

  .form-footnote {
    margin: -14px 0 0;
    color: #789097;
    font-size: 0.88rem;
    font-weight: 650;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .confirmation {
    text-align: center;
    padding: clamp(28px, 5vw, 58px) 18px;
  }

  .breathing-circle {
    width: 84px;
    height: 84px;
    margin: 0 auto 26px;
    border-radius: 999px;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.95), transparent 34%),
      rgba(158, 223, 227, 0.9);
    box-shadow: 0 0 0 12px rgba(158, 223, 227, 0.22);
    animation: breathe 8s ease-in-out infinite;
  }

  .confirmation h2 {
    max-width: 620px;
    margin-inline: auto;
  }

  .confirmation p:not(.eyebrow) {
    max-width: 620px;
    margin: 18px auto 0;
    color: #536b70;
    font-size: 1.05rem;
  }

  .confirmation-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  @media (max-width: 940px) {
    .hero-grid,
    .form-grid {
      grid-template-columns: 1fr;
    }

    .help-panel {
      max-width: 560px;
    }

    .privacy-note {
      position: static;
    }
  }

  @media (max-width: 620px) {
    .booking-hero {
      padding: 64px 0;
    }

    .field-grid,
    .choice-grid {
      grid-template-columns: 1fr;
    }

    .submit-button,
    .confirmation-actions a {
      width: 100%;
    }
  }
</style>
